{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VelocityRL",
  "version": "1.2.1",
  "identifier": "com.velocityrl.app",
  "build": {
    "frontendDist": "../ui",
    "beforeBuildCommand": "echo build"
  },
  "app": {
    "windows": [
      {
        "title": "VelocityRL",
        "width": 1000,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://api.velocityrl.tech data: blob:; connect-src 'self' https://api.velocityrl.tech https://velocityrl.tech https://api.github.com https://github.com"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../python/items.json",
      "../python/keys.txt"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "shell": {
      "open": "^https://(discord\\.gg|github\\.com|velocityrl\\.tech)"
    },
    "updater": {
      "endpoints": [
        "https://api.velocityrl.tech/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkgNzZBOEU1RDZCMDQwOEQ4NApSV1IycU9YV3NFQ05oTE5EdmNKWHFwZ3ErYmQzR3BQTndXMm1JQ3VFQWIrSmtYWDJBTVVGbVlCSwo="
    }
  }
}