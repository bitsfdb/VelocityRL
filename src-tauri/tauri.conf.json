{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VelocityRL",
  "version": "1.1.0",
  "identifier": "com.velocityrl.app",
  "build": {
    "frontendDist": "../ui",
    "beforeBuildCommand": "echo build"
  },
  "app": {
    "windows": [
      {
        "title": "VelocityRL",
        "width": 1000,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://api.sfdb.dev data: blob:; connect-src 'self' https://api.sfdb.dev https://velocityrl.me"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../python/items.json",
      "../python/keys.txt",
      "../python/engine.sha256",
      "../python/rl_upk_editor.py"
    ],
    "externalBin": [
      "bin/velocity-engine"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "shell": {
      "open": "^https://discord\\.gg/"
    }
  }
}
