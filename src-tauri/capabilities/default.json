{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "log:default",
    "process:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bin/velocity-engine",
          "sidecar": true,
          "args": [
            { "validator": "\\S+" },
            { "validator": "\\S+" },
            { "validator": "\\S+" },
            { "validator": "\\S+" },
            { "validator": "\\S+" },
            { "validator": "\\S+" },
            { "validator": "\\S+" },
            { "validator": "\\S+" },
            { "validator": "\\S+" },
            { "validator": "\\S+" }
          ]
        }
      ]
    },
    "shell:allow-open"
  ]
}
